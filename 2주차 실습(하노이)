#Fibonnacci 수열
#반복분
start = time.time()
total = 0
first = 0
second= 1
for i in range(2,11):
    total = first + second
    first = second
    second = total

print(total)
end=time.time()
print(end-start)

#순환
#시간복잡도 2^n
start=time.time()
def fibonacci(n):
  if n == 0:
    return 0
  elif n == 1:
    return 1
  else:
    return fibonacci(n-1) + fibonacci(n-2)

print(fibonacci(10))
end=time.time()
print(end-start)

