#하노이탑
def hanoi(m_1,m_2, m_3, n):
  if n== 1:
    print("가장 큰 원판",n,"을", m_1, "->", m_3)
  else:
    hanoi(m_1, m_3, m_2, n-1)
    print(n,"원판을", m_1,"->",m_3)
    hanoi(m_2, m_1, m_3, n-1)

hanoi("A", "B", "C", 3)