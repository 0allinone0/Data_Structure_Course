#자료 구조 리스트 생성
import time

start = time.time()
bag = []

#요소들 넣기
bag.append("핸드폰")
bag.append("보조배터리")
bag.append("텀블러")

#요소 확인 및 제거
def bagRemove(a):
    if a in bag:
        bag.remove(a)
    else:
        print("가방에 없는 물건입니다.")
    return len(bag)

#테스트
print(bagRemove("보조배터리"))

end = time.time()
print("실행 시간 : ", end - start)


