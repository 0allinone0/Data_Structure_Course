#Factorial 구현
#for 문은 빅오 시간복잡도(n)
#1000!는 숫자가 너무 커져서 오류가 남 100!으로 변경
start = time.time()
i = 1
total=1
for i in range(100):
  total *= (1+i)

print(total)
end=time.time()
print(end-start)


#순환구조는 시간 복잡도(n)
start= time.time()
def factorial(x):
  if x == 1:
    return 1
  return x * factorial(x-1)

print(factorial(100))
end= time.time()

print(end-start)

